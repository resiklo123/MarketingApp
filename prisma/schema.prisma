generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PostStatus {
  PROCESSING
  DRAFT_READY
  DRAFT
  POSTED
  ARCHIVED
  FAILED
}

model Post {
  id            String     @id @default(cuid())
  slug          String     @unique
  machine       String
  machineFamily String
  machineModel  String?
  topic         String
  location      String?
  platforms     String[]
  status        PostStatus @default(PROCESSING)
  createdAt     DateTime   @default(now())
  assets        Asset[]
  drafts        Draft[]
  logs          PostingLog[]
}

model Asset {
  id            String  @id @default(cuid())
  postId        String
  post          Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  driveFileId   String
  originalName  String
  finalName     String
  mimeType      String
  size          BigInt?
  webViewLink   String?
  thumbnailLink String?
}

model Draft {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform    String
  title       String?
  caption     String?
  hashtags    String?
  description String?
  version     Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt
}

model PostingLog {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform  String
  postedUrl String?
  postedAt  DateTime?
  postedBy  String?
  notes     String?
  updatedAt DateTime  @default(now()) @updatedAt

  @@unique([postId, platform])
}

model MachineModelOption {
  id        String   @id @default(cuid())
  family    String
  model     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([family, model])
}